@model List<Magazyn.Models.Dtos.UserListRowDto>
@{
    Layout = null;
    var selected = (string[])(ViewBag.SelectedRoles ?? Array.Empty<string>());
    
    // Lista ról - Label to tekst wyświetlany, Value to nazwa w bazie
    var allRoles = new (string Value, string Label)[]
    {
        ("Administrator",       "Administrator"),
        ("Pracownik magazynu",  "Pracownik magazynu"),
        ("Sprzedawca",          "Sprzedawca"),
        ("Kierownik magazynu",  "Kierownik magazynu"),
        ("Kierownik sprzedazy", "Kierownik sprzedaży")
    };
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Lista Uprawnień</title>
    <link rel="stylesheet" href="~/css/style.css" />
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
    <div class="Wrapper">
        <aside class="panelbok">
            <div class="logo"><h1>Magazyn GiTA</h1></div>
            <nav class="gitanav">
                <p>Zarządzanie użytkownikami</p>
                <ul>
                    <li><a asp-controller="Uzytkownicy" asp-action="AdminPanel">Przegląd personelu</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="Rejestracja">Rejestracja pracownika</a></li>
                    <li><a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">Użytkownicy zapomniani (RODO)</a></li>
                    <li><a asp-controller="Uprawnienia" asp-action="Uprawnienia" class="active">Lista Uprawnień</a></li>
                </ul>
            </nav>
        </aside>

        <main class="main">
            <header class="header">
                <div class="info">
                    <a href="#" id="akcja-wyloguj">Wyloguj</a>
                    <a href="#">Konto</a>
                    <a asp-controller="Home" asp-action="Index">Strona Główna</a>
                </div>
            </header>

            <section class="zaw">
                <h2>Lista Uprawnień</h2>

                <div class="search-bar">
                    <form method="get" id="filterForm" asp-controller="Uprawnienia" asp-action="Uprawnienia">
                        <label style="display:block; margin-bottom: 15px; font-weight: bold; color: var(--accent-blue);">
                            Filtruj użytkowników posiadających wszystkie zaznaczone role:
                        </label>
                        
                        <div class="role-checkbox-container" style="display: flex; flex-wrap: wrap; gap: 20px; margin-bottom: 20px;">
                            @foreach (var rola in allRoles)
                            {
                                <label class="custom-checkbox" style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
                                    <input type="checkbox" name="rola" value="@rola.Value" 
                                           onchange="this.form.submit()"
                                           @(selected.Contains(rola.Value) ? "checked" : "") />
                                    <span>@rola.Label</span>
                                </label>
                            }
                        </div>

                        <div class="btn-group">
                            @* Przycisk Filtruj usunięty - filtrowanie jest automatyczne *@
                            <a class="btn-secondary" asp-controller="Uprawnienia" asp-action="Uprawnienia">Wyczyść wszystkie filtry</a>
                        </div>
                    </form>
                </div>

                <div class="tabelka-wyniki">
                    <table>
                        <thead>
                            <tr>
                                <th>Login</th>
                                <th>Imię</th>
                                <th>Nazwisko</th>
                                <th>Email</th>
                                <th>PESEL</th>
                                <th>Status</th>
                                <th>Role</th>
                                <th>Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="8" class="no-results" style="text-align: center; padding: 40px; color: var(--error-red);">
                                        Brak użytkowników spełniających WSZYSTKIE wybrane kryteria ról.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var u in Model)
                                {
                                    <tr>
                                        <td><strong>@u.Username</strong></td>
                                        <td>@u.FirstName</td>
                                        <td>@u.LastName</td>
                                        <td>@u.Email</td>
                                        <td>@u.Pesel</td>
                                        <td>@u.Status</td>
                                        <td style="color: var(--accent-blue); font-size: 13px;">@u.Rola</td>
                                        <td>
                                            <a class="btn-secondary" 
                                               asp-controller="Uzytkownicy" 
                                               asp-action="UserDetails" 
                                               asp-route-id="@u.Id">
                                                Szczegóły
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>
</body>
</html>