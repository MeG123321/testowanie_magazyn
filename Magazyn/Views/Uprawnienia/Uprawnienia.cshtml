@model List<Magazyn.Models.Dtos.UserListRowDto>
@{
    Layout = null;

    var allRoles = new (string Value, string Label)[]
    {
        ("Administrator",       "Administrator"),
        ("Pracownik magazynu",  "Pracownik magazynu"),
        ("Sprzedawca",          "Sprzedawca"),
        ("Kierownik magazynu",  "Kierownik magazynu"),
        ("Kierownik sprzedazy", "Kierownik sprzedaży")
    };

    var selectedFilters = (string[])(ViewBag.SelectedRoles ?? Array.Empty<string>());

    var isAdmin = User.IsInRole("Administrator");
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Magazyn GiTA - Lista Uprawnień</title>
    <link rel="stylesheet" href="~/css/style.css" />

    <style>
        .role-btn:has(input:checked) {
            background-color: #28a745 !important;
            color: white !important;
            border-color: #1e7e34 !important;
        }

        .role-btn input:checked + span {
            background-color: #28a745 !important;
            color: white !important;
        }
    </style>
</head>

<body data-home-url='@Url.Action("Index", "Home")'>
<div class="Wrapper">

    <aside class="panelbok">
        <div class="logo"><h1>Magazyn GiTA</h1></div>

        <nav class="gitanav">
            <p>Zarządzanie użytkownikami</p>

            <ul>
                <li>
                    <a asp-controller="Uzytkownicy" asp-action="AdminPanel">
                        Przegląd personelu
                    </a>
                </li>

                <li>
                    <a asp-controller="Uzytkownicy" asp-action="Rejestracja">
                        Rejestracja pracownika
                    </a>
                </li>

                @* 🔥 TYLKO ADMIN WIDZI RODO *@
                @if (isAdmin)
                {
                    <li>
                        <a asp-controller="Uzytkownicy" asp-action="ForgottenUsers">
                            Użytkownicy zapomniani (RODO)
                        </a>
                    </li>
                }

                <li>
                    <a asp-controller="Uprawnienia"
                       asp-action="Uprawnienia"
                       class="active">
                        Lista Uprawnień
                    </a>
                </li>

                <li>
                    <partial name="_LogoutLink" />
                </li>
            </ul>
        </nav>
    </aside>

    <main class="main">
        <header class="header">
            <div class="info">
                <a href="#" id="akcja-wyloguj">Wyloguj</a>
                <a asp-controller="Home" asp-action="Index">Strona Główna</a>
            </div>
        </header>

        <section class="zaw">
            <h2>Lista Uprawnień</h2>

            @* FILTRY RÓL *@
            <div class="search-bar">
                <form method="get" asp-controller="Uprawnienia" asp-action="Uprawnienia">

                    <label style="display:block; margin-bottom:15px; font-weight:bold;">
                        Filtruj użytkowników (role):
                    </label>

                    <div class="role-grid horizontal">
                        @foreach (var rola in allRoles)
                        {
                            <label class="role-btn">
                                <input type="checkbox"
                                       name="rola"
                                       value="@rola.Value"
                                       onchange="this.form.submit()"
                                       @(selectedFilters.Contains(rola.Value) ? "checked" : "") />
                                @rola.Label
                            </label>
                        }
                    </div>

                    <div class="btn-group" style="margin-top:20px;">
                        <a class="btn-primary"
                           asp-controller="Uprawnienia"
                           asp-action="Uprawnienia">
                            Wyczyść filtry
                        </a>
                    </div>
                </form>
            </div>

            @* TABELA *@
            <div class="tabelka-wyniki">
                <table>
                    <thead>
                    <tr>
                        <th>Login</th>
                        <th>Imię</th>
                        <th>Nazwisko</th>
                        <th>Uprawnienia</th>
                        <th>Status</th>
                        <th>Akcje</th>
                    </tr>
                    </thead>

                    <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" style="text-align:center; padding:40px;">
                                Brak użytkowników
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var u in Model)
                        {
                            <tr>
                                <td><strong>@u.Username</strong></td>
                                <td>@u.FirstName</td>
                                <td>@u.LastName</td>
                                <td style="color:#007bff; font-weight:bold;">
                                    @u.Rola
                                </td>
                                <td>@u.Status</td>
                                <td>
                                    <a class="btn-secondary"
                                       asp-controller="Uzytkownicy"
                                       asp-action="UserDetails"
                                       asp-route-id="@u.Id">
                                        Szczegóły
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>

        </section>
    </main>

</div>
</body>
</html>